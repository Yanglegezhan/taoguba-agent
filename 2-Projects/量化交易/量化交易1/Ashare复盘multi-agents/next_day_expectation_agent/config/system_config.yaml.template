# 系统配置模板
# 复制此文件为 system_config.yaml 并填写实际配置

# 数据存储路径
data:
  base_path: "./data"
  stage1_output: "./data/stage1_output"
  stage2_output: "./data/stage2_output"
  stage3_output: "./data/stage3_output"
  historical_db: "./data/historical/gene_pool_history.db"
  logs_path: "./data/logs"

# 日志配置
logging:
  level: "INFO"  # DEBUG, INFO, WARNING, ERROR
  format: "{time:YYYY-MM-DD HH:mm:ss} | {level} | {name}:{function}:{line} - {message}"
  rotation: "100 MB"
  retention: "30 days"
  console_output: true
  file_output: true

# 时间配置
timing:
  stage1_run_time: "17:30"  # 收盘后运行时间
  stage2_run_time: "08:30"  # 早盘前运行时间
  stage3_run_time: "09:25:01"  # 竞价结束运行时间

# 推送配置
notification:
  enabled: true
  wechat:
    enabled: false
    webhook_url: ""
  email:
    enabled: false
    smtp_server: ""
    smtp_port: 587
    sender: ""
    password: ""
    recipients: []

# 性能配置
performance:
  max_workers: 4  # 并发处理数
  timeout: 30  # API调用超时时间（秒）
  retry_times: 3  # 重试次数
