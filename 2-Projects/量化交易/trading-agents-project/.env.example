# Binance API (使用Testnet进行模拟交易)
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here
BINANCE_USE_TESTNET=true

# 可选：实盘API（仅用于获取数据，不用于交易）
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# OpenAI API（用于Agent推理）
OPENAI_API_KEY=your_openai_api_key_here

# 交易配置
INITIAL_BALANCE=10000  # 模拟账户初始资金 USDT
MAX_POSITION_SIZE=0.1  # 单笔最大仓位（账户百分比）
MAX_DRAWDOWN_PER_TRADE=0.02  # 单笔最大回撤 2%
MAX_DAILY_LOSS=0.05  # 日最大亏损 5%

# 监控配置
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
