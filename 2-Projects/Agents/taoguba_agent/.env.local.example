# 淘股吧配置（必须）
TAOGUBA_COOKIE=your_cookie_here

# LLM配置（必须）
LLM_PROVIDER=minimax          # 可选: minimax, zhipu, deepseek, qwen, kimi
LLM_API_KEY=your_api_key
LLM_MODEL=MiniMax-M2.5
LLM_MAX_TOKENS=190000         # 最大token数，默认190000

# 飞书配置（可选，用于推送）
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 调度配置（可选）
SCHEDULER_ENABLED=true
